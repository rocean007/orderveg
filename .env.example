# Environment Variables Template
# Copy this file to .env.local and fill in your values

# ========================================
# DATABASE
# ========================================
# Get from: Vercel Postgres, Supabase, Neon, or local PostgreSQL
# Format: postgresql://user:password@host:5432/database?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/fresh_veggies"

# ========================================
# AUTHENTICATION
# ========================================
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters"

# NextAuth configuration
NEXTAUTH_URL="http://localhost:3000"
# For production, use your Vercel URL: https://your-app.vercel.app
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-key-minimum-32-characters"

# ========================================
# OPTIONAL - FUTURE FEATURES
# ========================================
# Stripe (for payments)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# STRIPE_SECRET_KEY=""

# Email service (e.g., SendGrid, Resend)
# EMAIL_SERVER_HOST=""
# EMAIL_SERVER_PORT=""
# EMAIL_SERVER_USER=""
# EMAIL_SERVER_PASSWORD=""
# EMAIL_FROM="noreply@freshveggies.com"

# Image upload (e.g., Cloudinary, UploadThing)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
